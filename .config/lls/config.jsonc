      "name": "orchestrator-8b-opus-iq4",
      "match": "orchestrator.*8b.*opus.*iq4",
      "override": {
        "ctx": 20480,
        "batch": 2048,
        "ubatch": 256,
        "threads": 8,
        "extra_args": [
          // "--top-p",
