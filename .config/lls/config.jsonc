    {
      "name": "qwen3-vl-4b-thinking",
      "match": "qwen3.*vl.*4b.*thinking",
      "override": {
        "ctx": 40960,
        "batch": 2048,
        "ubatch": 256,
        "threads": 8,
        "extra_args": [
          "--top-p",
          "0.95",
          "--top-k",
          "20",
          "--repeat-penalty",
          "1.0",
          "--temp",
          "1.0",

          // "--no-mmap",
          // "--flash-attn",
          // "1",
          "--chat-template-kwargs",
          "{\"enable_thinking\": false}"
        ]
      }
    },
    {
      "name": "qwen3-vl-4b-instruct",
      "match": "qwen3.*vl.*4b.*instruct",
      "override": {
        "ctx": 40960,
        "batch": 2048,
        "ubatch": 256,
        "threads": 8,
        "extra_args": [
          // "--no-mmap",
          // "--flash-attn",
          // "1",
          "--chat-template-kwargs",
          "{\"enable_thinking\": false}"
        ]
      }
    },
    {
      "name": "glm-4.6-flash",
      "match": "glm.*4.6.*flash",
      "override": {
        "ctx": 20480,
        "extra_args": [
          "-ctk",
          "q8_0",
          "-ctv",
          "q8_0",
          "--top-p",
          "0.6",
          "--top-k",
          "2",
          "--temp",
          "0.8",
          "--repeat-penalty",
          "1.1",
          // "--no-mmap",
          "--flash-attn",
          "on"
          // "--chat-template-kwargs",
          // "{\"enable_thinking\": false}"
        ]
      }
    },
    {
      "name": "qwen3-vl-8b",
      "match": "qwen3.*vl.*8b.*",
      "override": {
        "ctx": 20480,
        "batch": 2048,
        "ubatch": 256,
        "threads": 8,
        "extra_args": [
          // "--no-mmap",
          "--flash-attn",
          "on",
          "--chat-template-kwargs",
          "{\"enable_thinking\": false}"
        ]
      }

      // "params": {
      // // 텍스트 모델 공통 옵션은 기본값에서 가져오고,
